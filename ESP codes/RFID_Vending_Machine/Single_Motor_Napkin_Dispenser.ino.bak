#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <SPI.h>
#include <MFRC522.h>
#include <WiFi.h>
#include <WebServer.h>
#include <SD.h>

// Pin Definitions for ESP32
#define RST_PIN 22          // RFID Reset pin
#define SS_PIN 21           // RFID Chip Select pin
#define SD_CS_PIN 5         // SD Card Chip Select pin
#define RELAY_PIN 25        // Relay for Motor
#define RESET_PIN 27        // Reset stock button

// Constants
#define MAX_STOCK 30
#define MAX_RFID_TAGS 50
#define DAILY_VEND_LIMIT 10

// LCD and RFID Objects
LiquidCrystal_I2C lcd(0x27, 16, 2);
MFRC522 mfrc522(SS_PIN, RST_PIN);
WebServer server(80);

// WiFi Configuration
const char* ssid = "Lyra-Vending-AP";
const char* password = "lyra12345";

// Data Structures
struct RFIDTag {
    char uid[32];
    int dailyCount;
    unsigned long lastResetDay;
    bool isActive;
};

struct Transaction {
    char uid[32];
    unsigned long timestamp;
};

RFIDTag authorizedTags[MAX_RFID_TAGS];
int tagCount = 0;
int currentStock = MAX_STOCK;
unsigned long currentDay = 0;

// File names
const char* TAGS_FILE = "/tags.txt";
const char* LOG_FILE = "/vendlog.csv";
const char* CONFIG_FILE = "/config.txt";

void setup() {
    Serial.begin(115200);
    
    // Initialize pins
    pinMode(RELAY_PIN, OUTPUT);
    pinMode(RESET_PIN, INPUT_PULLUP);
    digitalWrite(RELAY_PIN, LOW);
    
    // Initialize LCD
    lcd.init();
    lcd.backlight();
    lcd.setCursor(0, 0);
    lcd.print("Initializing...");
    
    // Initialize SPI
    SPI.begin();
    
    // Initialize RFID
    mfrc522.PCD_Init();
    delay(100);
    
    // Initialize SD Card
    if (!SD.begin(SD_CS_PIN)) {
        lcd.clear();
        lcd.setCursor(0, 0);
        lcd.print("SD Card Failed!");
        delay(2000);
    } else {
        lcd.clear();
        lcd.setCursor(0, 0);
        lcd.print("SD Card Ready");
        delay(1000);
        initializeSDCard();
    }
    
    // Load configuration
    loadConfiguration();
    loadAuthorizedTags();
    
    // Setup WiFi Access Point
    WiFi.mode(WIFI_AP);
    WiFi.softAP(ssid, password);
    
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("WiFi: ");
    lcd.print(WiFi.softAPIP());
    delay(2000);
    
    // Setup Web Server Routes
    setupWebServer();
    server.begin();
    
    // Calculate current day
    currentDay = millis() / 86400000UL;
    
    showIdleMessage();
}

void loop() {
    server.handleClient();
    
    // Reset stock
    if (digitalRead(RESET_PIN) == LOW) {
        currentStock = MAX_STOCK;
        saveConfiguration();
        lcd.clear();
        lcd.setCursor(0, 0);
        lcd.print("Stock Refilled");
        lcd.setCursor(0, 1);
        lcd.print("Napkins: 30");
        delay(2000);
        showIdleMessage();
        while(digitalRead(RESET_PIN) == LOW) delay(50);
    }
    
    // Check for RFID card
    if (mfrc522.PICC_IsNewCardPresent() && mfrc522.PICC_ReadCardSerial()) {
        String uid = getUID();
        handleRFIDScan(uid);
        mfrc522.PICC_HaltA();
        delay(1000);
    }
}

String getUID() {
    String uid = "";
    for (byte i = 0; i < mfrc522.uid.size; i++) {
        if (mfrc522.uid.uidByte[i] < 0x10) uid += "0";
        uid += String(mfrc522.uid.uidByte[i], HEX);
    }
    uid.toUpperCase();
    return uid;
}

void handleRFIDScan(String uid) {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Card Detected");
    lcd.setCursor(0, 1);
    lcd.print(uid.substring(0, 16));
    delay(1000);
    
    // Check if tag is authorized
    int tagIndex = findTagIndex(uid);
    
    if (tagIndex == -1) {
        lcd.clear();
        lcd.setCursor(0, 0);
        lcd.print("Unauthorized");
        lcd.setCursor(0, 1);
        lcd.print("Card!");
        delay(2000);
        showIdleMessage();
        return;
    }
    
    // Reset daily count if new day
    unsigned long today = millis() / 86400000UL;
    if (today != authorizedTags[tagIndex].lastResetDay) {
        authorizedTags[tagIndex].dailyCount = 0;
        authorizedTags[tagIndex].lastResetDay = today;
        saveAuthorizedTags();
    }
    
    // Check daily limit
    if (authorizedTags[tagIndex].dailyCount >= DAILY_VEND_LIMIT) {
        lcd.clear();
        lcd.setCursor(0, 0);
        lcd.print("Daily Limit");
        lcd.setCursor(0, 1);
        lcd.print("Reached!");
        delay(2000);
        showIdleMessage();
        return;
    }
    
    // Vend directly (no motor selection needed)
    vendItem(uid, tagIndex);
}

void vendItem(String uid, int tagIndex) {
    if (currentStock <= 0) {
        lcd.clear();
        lcd.setCursor(0, 0);
        lcd.print("Out of Stock!");
        lcd.setCursor(0, 1);
        lcd.print("Please Refill");
        delay(2000);
        showIdleMessage();
        return;
    }
    
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Dispensing...");
    delay(1000);
    
    // Activate motor
    digitalWrite(RELAY_PIN, HIGH);
    delay(2850); // Motor run time
    digitalWrite(RELAY_PIN, LOW);
    
    // Update stock and daily count
    currentStock--;
    authorizedTags[tagIndex].dailyCount++;
    
    // Save changes
    saveConfiguration();
    saveAuthorizedTags();
    
    // Log transaction
    logTransaction(uid);
    
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Please Collect");
    lcd.setCursor(0, 1);
    lcd.print("Your Napkin");
    delay(3000);
    
    // Show remaining quota
    int remaining = DAILY_VEND_LIMIT - authorizedTags[tagIndex].dailyCount;
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Today: ");
    lcd.print(authorizedTags[tagIndex].dailyCount);
    lcd.print("/");
    lcd.print(DAILY_VEND_LIMIT);
    lcd.setCursor(0, 1);
    lcd.print("Stock Left: ");
    lcd.print(currentStock);
    delay(2000);
    
    showIdleMessage();
}

int findTagIndex(String uid) {
    for (int i = 0; i < tagCount; i++) {
        if (String(authorizedTags[i].uid) == uid && authorizedTags[i].isActive) {
            return i;
        }
    }
    return -1;
}

void logTransaction(String uid) {
    File logFile = SD.open(LOG_FILE, FILE_WRITE);
    if (logFile) {
        unsigned long timestamp = millis() / 1000;
        logFile.print(uid);
        logFile.print(",");
        logFile.print(timestamp);
        logFile.print(",");
        logFile.println(getFormattedDateTime());
        logFile.close();
    }
}

String getFormattedDateTime() {
    unsigned long seconds = millis() / 1000;
    unsigned long days = seconds / 86400;
    unsigned long hours = (seconds % 86400) / 3600;
    unsigned long minutes = (seconds % 3600) / 60;
    unsigned long secs = seconds % 60;
    
    String dateTime = String(days) + "d " + 
                      String(hours) + "h " + 
                      String(minutes) + "m " + 
                      String(secs) + "s";
    return dateTime;
}

void showIdleMessage() {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Lyra Enterprises");
    lcd.setCursor(0, 1);
    lcd.print("Napkins: ");
    lcd.print(currentStock);
}

void initializeSDCard() {
    // Create log file if doesn't exist
    if (!SD.exists(LOG_FILE)) {
        File logFile = SD.open(LOG_FILE, FILE_WRITE);
        if (logFile) {
            logFile.println("UID,Timestamp,DateTime");
            logFile.close();
        }
    }
    
    // Create tags file
    if (!SD.exists(TAGS_FILE)) {
        File tagsFile = SD.open(TAGS_FILE, FILE_WRITE);
        if (tagsFile) {
            tagsFile.close();
        }
    }
    
    // Create config file
    if (!SD.exists(CONFIG_FILE)) {
        File configFile = SD.open(CONFIG_FILE, FILE_WRITE);
        if (configFile) {
            configFile.print("stock=");
            configFile.println(MAX_STOCK);
            configFile.close();
        }
    }
}

void loadConfiguration() {
    if (SD.exists(CONFIG_FILE)) {
        File configFile = SD.open(CONFIG_FILE, FILE_READ);
        if (configFile) {
            while (configFile.available()) {
                String line = configFile.readStringUntil('\n');
                line.trim();
                if (line.startsWith("stock=")) {
                    currentStock = line.substring(6).toInt();
                }
            }
            configFile.close();
        }
    }
}

void saveConfiguration() {
    SD.remove(CONFIG_FILE);
    File configFile = SD.open(CONFIG_FILE, FILE_WRITE);
    if (configFile) {
        configFile.print("stock=");
        configFile.println(currentStock);
        configFile.close();
    }
}

void loadAuthorizedTags() {
    tagCount = 0;
    if (SD.exists(TAGS_FILE)) {
        File tagsFile = SD.open(TAGS_FILE, FILE_READ);
        if (tagsFile) {
            while (tagsFile.available() && tagCount < MAX_RFID_TAGS) {
                String line = tagsFile.readStringUntil('\n');
                line.trim();
                if (line.length() > 0) {
                    int comma1 = line.indexOf(',');
                    int comma2 = line.indexOf(',', comma1 + 1);
                    int comma3 = line.indexOf(',', comma2 + 1);
                    
                    if (comma1 > 0) {
                        String uid = line.substring(0, comma1);
                        uid.toCharArray(authorizedTags[tagCount].uid, 32);
                        authorizedTags[tagCount].dailyCount = line.substring(comma1 + 1, comma2).toInt();
                        authorizedTags[tagCount].lastResetDay = line.substring(comma2 + 1, comma3).toInt();
                        authorizedTags[tagCount].isActive = line.substring(comma3 + 1).toInt() == 1;
                        tagCount++;
                    }
                }
            }
            tagsFile.close();
        }
    }
}

void saveAuthorizedTags() {
    SD.remove(TAGS_FILE);
    File tagsFile = SD.open(TAGS_FILE, FILE_WRITE);
    if (tagsFile) {
        for (int i = 0; i < tagCount; i++) {
            tagsFile.print(authorizedTags[i].uid);
            tagsFile.print(",");
            tagsFile.print(authorizedTags[i].dailyCount);
            tagsFile.print(",");
            tagsFile.print(authorizedTags[i].lastResetDay);
            tagsFile.print(",");
            tagsFile.println(authorizedTags[i].isActive ? 1 : 0);
        }
        tagsFile.close();
    }
}

void setupWebServer() {
    server.on("/", HTTP_GET, handleRoot);
    server.on("/api/stats", HTTP_GET, handleStats);
    server.on("/api/logs", HTTP_GET, handleLogs);
    server.on("/api/tags", HTTP_GET, handleGetTags);
    server.on("/api/tags/add", HTTP_POST, handleAddTag);
    server.on("/api/tags/delete", HTTP_POST, handleDeleteTag);
    server.on("/api/tags/toggle", HTTP_POST, handleToggleTag);
    server.on("/download/logs", HTTP_GET, handleDownloadLogs);
    server.on("/api/reset-stock", HTTP_POST, handleResetStock);
}

void handleRoot() {
    String html = R"(
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lyra Napkin Dispenser</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container { max-width: 1200px; margin: 0 auto; }
        .header {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            margin-bottom: 20px;
            text-align: center;
        }
        .header h1 { color: #667eea; font-size: 2.5em; margin-bottom: 10px; }
        .header p { color: #666; font-size: 1.1em; }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }
        .stat-card {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            text-align: center;
        }
        .stat-card h3 {
            color: #666;
            font-size: 0.9em;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }
        .stat-card .value { font-size: 2.5em; font-weight: bold; color: #667eea; }
        .section {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            margin-bottom: 20px;
        }
        .section h2 { color: #667eea; margin-bottom: 20px; font-size: 1.8em; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }
        th { background: #f8f9fa; color: #667eea; font-weight: 600; }
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1em;
            transition: all 0.3s;
        }
        .btn-primary { background: #667eea; color: white; }
        .btn-primary:hover { background: #5568d3; transform: translateY(-2px); }
        .btn-danger { background: #e74c3c; color: white; }
        .btn-success { background: #27ae60; color: white; }
        .btn-small { padding: 5px 12px; font-size: 0.9em; margin: 0 5px; }
        .input-group { margin: 15px 0; }
        .input-group label { display: block; margin-bottom: 5px; color: #666; font-weight: 500; }
        .input-group input {
            width: 100%;
            padding: 12px;
            border: 2px solid #eee;
            border-radius: 8px;
            font-size: 1em;
        }
        .input-group input:focus { outline: none; border-color: #667eea; }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            justify-content: center;
            align-items: center;
        }
        .modal-content {
            background: white;
            padding: 30px;
            border-radius: 15px;
            max-width: 500px;
            width: 90%;
        }
        .log-table { max-height: 400px; overflow-y: auto; }
        .status-badge { padding: 5px 10px; border-radius: 20px; font-size: 0.85em; font-weight: 600; }
        .status-active { background: #d4edda; color: #155724; }
        .status-inactive { background: #f8d7da; color: #721c24; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🧻 Lyra Napkin Dispenser</h1>
            <p>Single Motor System - Dashboard</p>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>Napkins Left</h3>
                <div class="value" id="stock">--</div>
            </div>
            <div class="stat-card">
                <h3>Total Dispensed</h3>
                <div class="value" id="totalTrans">--</div>
            </div>
            <div class="stat-card">
                <h3>Active RFID Tags</h3>
                <div class="value" id="activeTags">--</div>
            </div>
        </div>

        <div class="section">
            <h2>RFID Tag Management</h2>
            <button class="btn btn-primary" onclick="showAddTagModal()">+ Add New RFID Tag</button>
            <button class="btn btn-primary" onclick="loadTags()">🔄 Refresh</button>
            <div id="tagsTable" style="margin-top: 20px;"></div>
        </div>

        <div class="section">
            <h2>Recent Transactions</h2>
            <button class="btn btn-success" onclick="downloadLogs()">Download Logs (CSV)</button>
            <button class="btn btn-primary" onclick="loadLogs()">🔄 Refresh</button>
            <div class="log-table">
                <table id="logsTable">
                    <thead>
                        <tr><th>RFID UID</th><th>Timestamp</th><th>Date/Time</th></tr>
                    </thead>
                    <tbody id="logsBody">
                        <tr><td colspan="3" style="text-align:center;">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="section">
            <h2>System Actions</h2>
            <button class="btn btn-danger" onclick="resetStock()">🔄 Refill Stock (30 Napkins)</button>
        </div>
    </div>

    <div id="addTagModal" class="modal">
        <div class="modal-content">
            <h2>Add New RFID Tag</h2>
            <div class="input-group">
                <label>RFID UID (Hex Format)</label>
                <input type="text" id="newTagUID" placeholder="e.g., A1B2C3D4">
            </div>
            <button class="btn btn-primary" onclick="addTag()">Add Tag</button>
            <button class="btn btn-danger" onclick="hideAddTagModal()">Cancel</button>
        </div>
    </div>

    <script>
        function loadStats() {
            fetch('/api/stats')
                .then(r => r.json())
                .then(data => {
                    document.getElementById('stock').textContent = data.stock;
                    document.getElementById('totalTrans').textContent = data.totalTransactions;
                    document.getElementById('activeTags').textContent = data.activeTags;
                });
        }

        function loadLogs() {
            fetch('/api/logs')
                .then(r => r.json())
                .then(data => {
                    let html = '';
                    data.logs.forEach(log => {
                        html += `<tr>
                            <td>${log.uid}</td>
                            <td>${log.timestamp}</td>
                            <td>${log.dateTime}</td>
                        </tr>`;
                    });
                    document.getElementById('logsBody').innerHTML = html || '<tr><td colspan="3" style="text-align:center;">No transactions yet</td></tr>';
                });
        }

        function loadTags() {
            fetch('/api/tags')
                .then(r => r.json())
                .then(data => {
                    let html = '<table><thead><tr><th>UID</th><th>Daily Count</th><th>Status</th><th>Actions</th></tr></thead><tbody>';
                    data.tags.forEach(tag => {
                        const status = tag.active ? 'Active' : 'Inactive';
                        const statusClass = tag.active ? 'status-active' : 'status-inactive';
                        html += `<tr>
                            <td>${tag.uid}</td>
                            <td>${tag.dailyCount}/${tag.limit}</td>
                            <td><span class="status-badge ${statusClass}">${status}</span></td>
                            <td>
                                <button class="btn btn-small btn-primary" onclick="toggleTag('${tag.uid}')">Toggle</button>
                                <button class="btn btn-small btn-danger" onclick="deleteTag('${tag.uid}')">Delete</button>
                            </td>
                        </tr>`;
                    });
                    html += '</tbody></table>';
                    document.getElementById('tagsTable').innerHTML = html;
                });
        }

        function showAddTagModal() { document.getElementById('addTagModal').style.display = 'flex'; }
        function hideAddTagModal() { document.getElementById('addTagModal').style.display = 'none'; }

        function addTag() {
            const uid = document.getElementById('newTagUID').value.trim().toUpperCase();
            if (!uid) { alert('Please enter a valid UID'); return; }
            fetch('/api/tags/add', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: 'uid=' + uid
            })
            .then(r => r.text())
            .then(data => {
                alert(data);
                hideAddTagModal();
                loadTags();
                loadStats();
            });
        }

        function deleteTag(uid) {
            if (!confirm('Delete tag ' + uid + '?')) return;
            fetch('/api/tags/delete', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: 'uid=' + uid
            })
            .then(r => r.text())
            .then(data => { alert(data); loadTags(); loadStats(); });
        }

        function toggleTag(uid) {
            fetch('/api/tags/toggle', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: 'uid=' + uid
            })
            .then(r => r.text())
            .then(data => { alert(data); loadTags(); loadStats(); });
        }

        function downloadLogs() { window.location.href = '/download/logs'; }

        function resetStock() {
            if (!confirm('Refill stock to 30 napkins?')) return;
            fetch('/api/reset-stock', {method: 'POST'})
                .then(r => r.text())
                .then(data => { alert(data); loadStats(); });
        }

        loadStats();
        loadLogs();
        loadTags();
        setInterval(() => { loadStats(); loadLogs(); loadTags(); }, 10000);
    </script>
</body>
</html>
)";
    server.send(200, "text/html", html);
}

void handleStats() {
    File logFile = SD.open(LOG_FILE, FILE_READ);
    int transactionCount = 0;
    if (logFile) {
        while (logFile.available()) {
            logFile.readStringUntil('\n');
            transactionCount++;
        }
        transactionCount--;
        if (transactionCount < 0) transactionCount = 0;
        logFile.close();
    }
    
    int activeCount = 0;
    for (int i = 0; i < tagCount; i++) {
        if (authorizedTags[i].isActive) activeCount++;
    }
    
    String json = "{";
    json += "\"stock\":" + String(currentStock) + ",";
    json += "\"totalTransactions\":" + String(transactionCount) + ",";
    json += "\"activeTags\":" + String(activeCount);
    json += "}";
    
    server.send(200, "application/json", json);
}

void handleLogs() {
    String json = "{\"logs\":[";
    File logFile = SD.open(LOG_FILE, FILE_READ);
    if (logFile) {
        bool firstLine = true;
        bool isHeader = true;
        while (logFile.available()) {
            String line = logFile.readStringUntil('\n');
            line.trim();
            if (isHeader) { isHeader = false; continue; }
            if (line.length() > 0) {
                if (!firstLine) json += ",";
                firstLine = false;
                
                int comma1 = line.indexOf(',');
                int comma2 = line.indexOf(',', comma1 + 1);
                
                String uid = line.substring(0, comma1);
                String timestamp = line.substring(comma1 + 1, comma2);
                String dateTime = line.substring(comma2 + 1);
                
                json += "{\"uid\":\"" + uid + "\",";
                json += "\"timestamp\":\"" + timestamp + "\",";
                json += "\"dateTime\":\"" + dateTime + "\"}";
            }
        }
        logFile.close();
    }
    json += "]}";
    server.send(200, "application/json", json);
}

void handleGetTags() {
    String json = "{\"tags\":[";
    for (int i = 0; i < tagCount; i++) {
        if (i > 0) json += ",";
        json += "{\"uid\":\"" + String(authorizedTags[i].uid) + "\",";
        json += "\"dailyCount\":" + String(authorizedTags[i].dailyCount) + ",";
        json += "\"limit\":" + String(DAILY_VEND_LIMIT) + ",";
        json += "\"active\":" + String(authorizedTags[i].isActive ? "true" : "false") + "}";
    }
    json += "]}";
    server.send(200, "application/json", json);
}

void handleAddTag() {
    if (server.hasArg("uid")) {
        String uid = server.arg("uid");
        uid.toUpperCase();
        
        if (findTagIndex(uid) != -1) {
            server.send(400, "text/plain", "Tag already exists!");
            return;
        }
        
        if (tagCount >= MAX_RFID_TAGS) {
            server.send(400, "text/plain", "Maximum tag limit reached!");
            return;
        }
        
        uid.toCharArray(authorizedTags[tagCount].uid, 32);
        authorizedTags[tagCount].dailyCount = 0;
        authorizedTags[tagCount].lastResetDay = currentDay;
        authorizedTags[tagCount].isActive = true;
        tagCount++;
        
        saveAuthorizedTags();
        server.send(200, "text/plain", "Tag added successfully!");
    } else {
        server.send(400, "text/plain", "Missing UID parameter");
    }
}

void handleDeleteTag() {
    if (server.hasArg("uid")) {
        String uid = server.arg("uid");
        int index = findTagIndex(uid);
        
        if (index == -1) {
            server.send(400, "text/plain", "Tag not found!");
            return;
        }
        
        for (int i = index; i < tagCount - 1; i++) {
            authorizedTags[i] = authorizedTags[i + 1];
        }
        tagCount--;
        
        saveAuthorizedTags();
        server.send(200, "text/plain", "Tag deleted successfully!");
    } else {
        server.send(400, "text/plain", "Missing UID parameter");
    }
}

void handleToggleTag() {
    if (server.hasArg("uid")) {
        String uid = server.arg("uid");
        int index = -1;
        
        for (int i = 0; i < tagCount; i++) {
            if (String(authorizedTags[i].uid) == uid) {
                index = i;
                break;
            }
        }
        
        if (index == -1) {
            server.send(400, "text/plain", "Tag not found!");
            return;
        }
        
        authorizedTags[index].isActive = !authorizedTags[index].isActive;
        saveAuthorizedTags();
        
        String status = authorizedTags[index].isActive ? "activated" : "deactivated";
        server.send(200, "text/plain", "Tag " + status + " successfully!");
    } else {
        server.send(400, "text/plain", "Missing UID parameter");
    }
}

void handleDownloadLogs() {
    if (!SD.exists(LOG_FILE)) {
        server.send(404, "text/plain", "No logs found");
        return;
    }
    
    File logFile = SD.open(LOG_FILE, FILE_READ);
    if (!logFile) {
        server.send(500, "text/plain", "Error opening log file");
        return;
    }
    
    server.sendHeader("Content-Disposition", "attachment; filename=napkin_logs.csv");
    server.streamFile(logFile, "text/csv");
    logFile.close();
}

void handleResetStock() {
    currentStock = MAX_STOCK;
    saveConfiguration();
    server.send(200, "text/plain", "Stock refilled to 30 napkins!");
}
